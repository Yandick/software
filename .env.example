# Development and demo defaults.
OPS_ENVIRONMENT=development
OPS_APP_VERSION=1.0.0-demo
OPS_DATABASE_URL=sqlite:///backend/data/app.db
OPS_JWT_SECRET=please-change-this-secret-for-dev-only-32
OPS_SEED_DEMO_ACCOUNTS=true
OPS_CORS_ORIGINS=http://127.0.0.1:5666,http://localhost:5666

# Model service.
# VLLM_CUDA_VISIBLE_DEVICES=0,1
# OPS_EMBEDDING_CUDA_VISIBLE_DEVICES=2
OPS_MODEL_PATH=models/qwen3-1.7b
OPS_VLLM_BASE_URL=http://127.0.0.1:8000/v1
OPS_VLLM_MODEL_NAME=qwen3-1.7b
OPS_ENABLE_THINKING=false
OPS_ENABLE_EMBEDDING_RAG=true
OPS_EMBEDDING_MODEL_PATH=models/qwen3-embedding-0.6b
OPS_EMBEDDING_DEVICE=auto
OPS_EMBEDDING_BATCH_SIZE=8
OPS_EMBEDDING_MAX_LENGTH=8192
OPS_EMBEDDING_DIMENSION=1024
OPS_EMBEDDING_INDEX_DIR=backend/data/vector_index
OPS_EMBEDDING_INDEX_BACKEND=auto
OPS_ENABLE_AGENT_LLM=false
OPS_AGENT_LLM_PARALLELISM=5
OPS_AGENT_LLM_TIMEOUT_SECONDS=45
OPS_ENABLE_INTENT_ROUTER_LLM=false
OPS_INTENT_ROUTER_LLM_MIN_CONFIDENCE=0.72
OPS_MAX_NEW_TOKENS=512
OPS_TEMPERATURE=0.6
OPS_TOP_P=0.95

# Server ports used by scripts/start_all.sh.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5666
# Optional explicit Vite dev proxy target. Defaults to http://$BACKEND_HOST:$BACKEND_PORT/api.
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8010/api

# Production checklist:
# OPS_ENVIRONMENT=production
# OPS_JWT_SECRET=<generate-a-random-secret-with-at-least-32-characters>
# OPS_SEED_DEMO_ACCOUNTS=false
# OPS_ADMIN_PASSWORD=<only-for-non-interactive-scripts; prefer an interactive prompt>
